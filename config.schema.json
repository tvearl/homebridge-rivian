{
  "pluginAlias": "RivianHomebridge",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Control your Rivian from Apple Home. Use the **Sign in & enroll** panel above to connect your account, then choose which controls to expose below.",
  "footerDisplay": "Unofficial plugin - not affiliated with Rivian. Enrolling uses one of your two phone-key slots per vehicle.",
  "schema": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Rivian"
      },
      "pollIntervalSeconds": {
        "title": "Polling interval (seconds)",
        "type": "integer",
        "default": 60,
        "minimum": 30,
        "maximum": 3600,
        "description": "How often to refresh vehicle state. Lower values update faster but use more API calls and battery."
      },
      "enableLock": {
        "title": "Lock / unlock (all closures)",
        "type": "boolean",
        "default": true
      },
      "enableBattery": {
        "title": "Battery % and charging status",
        "type": "boolean",
        "default": true
      },
      "enableClimate": {
        "title": "Cabin climate (thermostat: current temp + preconditioning)",
        "type": "boolean",
        "default": true
      },
      "enableFrontSeats": {
        "title": "Front seats heating + cooling (Driver & Passenger tiles)",
        "type": "boolean",
        "default": false
      },
      "enableRearSeatHeat": {
        "title": "Second-row seat heating",
        "type": "boolean",
        "default": false
      },
      "enableSteeringHeat": {
        "title": "Heated steering wheel",
        "type": "boolean",
        "default": false
      },
      "enableThirdRowHeat": {
        "title": "Third-row seat heating (R1S only)",
        "type": "boolean",
        "default": false
      },
      "enableGearTunnel": {
        "title": "Gear tunnel side bins (R1T only)",
        "type": "boolean",
        "default": false
      },
      "enableWindows": {
        "title": "Vent windows (open / close all)",
        "type": "boolean",
        "default": true
      },
      "enableFrunk": {
        "title": "Front trunk (frunk)",
        "type": "boolean",
        "default": true
      },
      "enableTailgate": {
        "title": "Rear trunk - tailgate (R1T) or powered liftgate (R1S)",
        "type": "boolean",
        "default": false
      },
      "enableTonneau": {
        "title": "Powered tonneau cover (R1T only; ignored on R1S)",
        "type": "boolean",
        "default": false
      },
      "debug": {
        "title": "Verbose debug logging",
        "type": "boolean",
        "default": false
      }
    }
  },
  "layout": [
    "name",
    "pollIntervalSeconds",
    {
      "type": "fieldset",
      "title": "Controls to expose",
      "expandable": true,
      "expanded": true,
      "items": [
        "enableLock",
        "enableBattery",
        "enableClimate",
        "enableFrontSeats",
        "enableRearSeatHeat",
        "enableSteeringHeat",
        "enableThirdRowHeat",
        "enableWindows",
        "enableFrunk",
        "enableTailgate",
        "enableTonneau",
        "enableGearTunnel"
      ]
    },
    {
      "type": "fieldset",
      "title": "Advanced",
      "expandable": true,
      "expanded": false,
      "items": ["debug"]
    }
  ]
}
